---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import OgDefault from '../../assets/og-default.png';
import { SITE_TITLE } from '../../consts';

const now = new Date();
const posts = (await getCollection('blog'))
	.filter((post) => post.data.pubDate <= now)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const categories = ['All', ...new Set(posts.map((p) => p.data.category))];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`All Reviews | ${SITE_TITLE}`}
			description="Manga and book reviews with cultural insights from Japan."
		/>
	</head>
	<body>
		<Header />
		<main>
			<h1 class="text-2xl font-bold mb-6">All Reviews</h1>

			<!-- Category Filter -->
			<div class="flex flex-wrap gap-2 mb-8">
				{categories.map((cat) => (
					<button
						class="category-btn px-3 py-1 text-sm rounded-full bg-white text-gray-600 hover:bg-amber-50 hover:text-amber-600 shadow-sm transition cursor-pointer border-none"
						data-category={cat}
					>
						{cat}
					</button>
				))}
			</div>

			<!-- Post Grid -->
			<div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="post-grid">
				{posts.map((post) => (
					<article
						class="post-card bg-white rounded-lg shadow-sm overflow-hidden hover:shadow-md transition"
						data-category={post.data.category}
					>
						<a href={`/blog/${post.id}/`} class="no-underline flex gap-4 h-full">
							<div class="w-20 min-h-[112px] bg-gray-100 flex-shrink-0 flex items-center justify-center overflow-hidden">
								{post.data.amazonASIN ? (
									<img
										src={`https://m.media-amazon.com/images/P/${post.data.amazonASIN}.jpg`}
										alt={post.data.title}
										class="h-full w-full object-cover"
										loading="lazy"
									/>
								) : (
									<Image
										src={OgDefault}
										alt={post.data.title}
										class="w-full h-full object-cover"
										widths={[96]}
									/>
								)}
							</div>
							<div class="py-3 pr-4 flex-1 flex flex-col">
								<span class="text-xs text-amber-600 bg-amber-50 px-2 py-0.5 rounded self-start">
									{post.data.category}
								</span>
								<h2 class="text-sm font-bold mt-1 mb-1 text-gray-800 leading-snug line-clamp-2">
									{post.data.title}
								</h2>
								<div class="flex items-center gap-3 mt-auto">
									<time class="text-xs text-gray-400">
										<FormattedDate date={post.data.pubDate} />
									</time>
									{post.data.rating && (
										<span class="text-xs font-bold text-amber-600">{post.data.rating}/10</span>
									)}
								</div>
							</div>
						</a>
					</article>
				))}
			</div>
		</main>
		<Footer />

		<script>
			document.querySelectorAll('.category-btn').forEach((btn) => {
				btn.addEventListener('click', () => {
					const category = (btn as HTMLElement).dataset.category;
					document.querySelectorAll('.post-card').forEach((card) => {
						const el = card as HTMLElement;
						if (category === 'All' || el.dataset.category === category) {
							el.style.display = '';
						} else {
							el.style.display = 'none';
						}
					});
					document.querySelectorAll('.category-btn').forEach((b) => {
						b.classList.remove('bg-amber-600', 'text-white');
						b.classList.add('bg-white', 'text-gray-600');
					});
					btn.classList.remove('bg-white', 'text-gray-600');
					btn.classList.add('bg-amber-600', 'text-white');
				});
			});
		</script>
	</body>
</html>
