---
const today = new Date();
---

<footer class="footer-gradient text-center py-10 mt-12 text-sm">
	<div class="max-w-[960px] mx-auto px-4">
		<div class="flex items-center justify-center gap-2 mb-4">
			<img src="/images/logo-icon.png" alt="" class="w-6 h-6 rounded" />
			<span class="font-bold text-amber-200 text-base">Tokyo Manga Shelf</span>
		</div>
		<div class="flex justify-center gap-6 mb-4">
			<a href="/about" class="text-amber-100/70 hover:text-amber-100 no-underline transition">About</a>
			<a href="/privacy" class="text-amber-100/70 hover:text-amber-100 no-underline transition">Privacy Policy</a>
			<a href="/terms" class="text-amber-100/70 hover:text-amber-100 no-underline transition">Terms of Service</a>
			<a href="/contact" class="text-amber-100/70 hover:text-amber-100 no-underline transition">Contact</a>
		</div>
		<p class="m-0 text-amber-100/50">&copy; {today.getFullYear()} Tokyo Manga Shelf. All rights reserved.</p>
	</div>
</footer>

<style>
	.footer-gradient {
		background: linear-gradient(135deg, #1c1917 0%, #292524 50%, #44403c 100%);
	}
</style>
