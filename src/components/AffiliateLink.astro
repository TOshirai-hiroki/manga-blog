---
interface Props {
	href: string;
	text: string;
	badge?: string;
}

const { href, text, badge = 'View on Amazon' } = Astro.props;
---

<div class="affiliate-link my-4 p-4 bg-amber-50 border border-amber-200 rounded-lg text-center">
	<a
		href={href}
		target="_blank"
		rel="nofollow noopener sponsored"
		class="inline-block px-6 py-3 bg-amber-600 !text-white rounded-lg !no-underline hover:bg-amber-700 hover:!text-white transition font-bold"
	>
		{text} — {badge}
	</a>
	<p class="text-xs text-gray-400 mt-2 mb-0">* As an Amazon Associate, I earn from qualifying purchases.</p>
</div>
