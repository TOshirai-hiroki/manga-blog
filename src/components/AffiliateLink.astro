---
interface Props {
	href: string;
	text: string;
	asin: string;
	badge?: string;
}

const { href, text, asin, badge = 'View on Amazon' } = Astro.props;
const imageUrl = `https://m.media-amazon.com/images/P/${asin}.01._SCLZZZZZZZ_SX200_.jpg`;
---

<div class="affiliate-link my-8 mx-auto max-w-sm p-5 bg-amber-50 border border-amber-200 rounded-lg text-center">
	<a
		href={href}
		target="_blank"
		rel="nofollow noopener sponsored"
		class="flex flex-col items-center gap-3 !no-underline hover:!no-underline"
	>
		<img
			src={imageUrl}
			alt={text}
			class="w-28 h-auto rounded shadow-md"
			loading="lazy"
		/>
		<span class="text-sm font-bold text-gray-800">{text}</span>
		<span class="inline-block px-5 py-2 bg-amber-600 !text-white rounded-lg hover:bg-amber-700 transition font-bold text-sm">
			{badge}
		</span>
	</a>
	<p class="text-xs text-gray-400 mt-3 mb-0">* As an Amazon Associate, I earn from qualifying purchases.</p>
</div>
