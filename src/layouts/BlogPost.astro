---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import AdBanner from '../components/AdBanner.astro';
import AffiliateLink from '../components/AffiliateLink.astro';
import { SITE_TITLE, AMAZON_ASSOCIATE_TAG } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, category, tags, rating, mangaAuthor, mangaTitleJa, amazonASIN, amazonTitle } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={`${title} | ${SITE_TITLE}`} description={description} type="article" />
		<script
			type="application/ld+json"
			set:html={JSON.stringify({
				'@context': 'https://schema.org',
				'@type': 'Article',
				headline: title,
				description: description,
				datePublished: pubDate.toISOString(),
				dateModified: (updatedDate || pubDate).toISOString(),
				author: { '@type': 'Organization', name: SITE_TITLE },
				publisher: { '@type': 'Organization', name: SITE_TITLE },
			})}
		/>
	</head>

	<body>
		<Header />
		<main>
			<article class="max-w-3xl mx-auto">
				<!-- Breadcrumb -->
				<nav class="text-sm text-gray-400 mb-4">
					<a href="/" class="hover:text-amber-600">Home</a>
					<span class="mx-1">/</span>
					<a href="/blog" class="hover:text-amber-600">Reviews</a>
					<span class="mx-1">/</span>
					<span class="text-gray-600">{title}</span>
				</nav>

				<header class="mb-8">
					<div class="flex items-center gap-3 mb-3">
						<span class="text-sm text-amber-600 bg-amber-50 px-3 py-1 rounded">{category}</span>
						<time class="text-sm text-gray-400"><FormattedDate date={pubDate} /></time>
						{updatedDate && (
							<span class="text-sm text-gray-400">
								(Updated: <FormattedDate date={updatedDate} />)
							</span>
						)}
					</div>
					<h1 class="text-2xl md:text-3xl font-bold leading-tight">{title}</h1>
					{mangaAuthor && (
						<p class="text-gray-500 mt-1">
							by {mangaAuthor}
							{mangaTitleJa && <span class="text-gray-400 ml-2">({mangaTitleJa})</span>}
						</p>
					)}
					{rating && (
						<div class="mt-2 text-lg font-bold text-amber-600">
							Rating: {rating}/10
						</div>
					)}
					{tags && tags.length > 0 && (
						<div class="flex flex-wrap gap-2 mt-3">
							{tags.map((tag: string) => (
								<span class="text-xs text-gray-500 bg-gray-100 px-2 py-1 rounded">#{tag}</span>
							))}
						</div>
					)}
				</header>

				<AdBanner position="top" />

				<div class="prose">
					<slot />
				</div>

				{amazonASIN && amazonTitle && (
					<AffiliateLink
						href={`https://www.amazon.com/dp/${amazonASIN}?tag=${AMAZON_ASSOCIATE_TAG}`}
						text={amazonTitle}
						asin={amazonASIN}
					/>
				)}

				<AdBanner position="bottom" />

				<div class="mt-12 pt-6 border-t border-gray-200 text-center">
					<a
						href="/blog"
						class="inline-block px-6 py-3 bg-amber-600 !text-white rounded-lg !no-underline hover:bg-amber-700 hover:!text-white transition"
					>
						Browse More Reviews
					</a>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
