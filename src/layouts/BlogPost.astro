---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import AdBanner from '../components/AdBanner.astro';
import AffiliateLink from '../components/AffiliateLink.astro';
import { SITE_TITLE, AMAZON_ASSOCIATE_TAG } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, category, tags, rating, mangaAuthor, mangaTitleJa, amazonASIN, amazonTitle } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Related posts: same category first, then fill from other categories
const now = new Date();
const allPosts = (await getCollection('blog')).filter(
	(post) => post.data.pubDate <= now && post.data.title !== title
);
const relatedPosts = allPosts
	.filter((post) => post.data.category === category)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
const remaining = 3 - relatedPosts.length;
if (remaining > 0) {
	const otherPosts = allPosts
		.filter((post) => post.data.category !== category)
		.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
		.slice(0, remaining);
	relatedPosts.push(...otherPosts);
}
---

<html lang="en">
	<head>
		<BaseHead title={`${title} | ${SITE_TITLE}`} description={description} image={heroImage} type="article" />
		<script
			type="application/ld+json"
			set:html={JSON.stringify({
				'@context': 'https://schema.org',
				'@type': 'Article',
				headline: title,
				description: description,
				datePublished: pubDate.toISOString(),
				dateModified: (updatedDate || pubDate).toISOString(),
				mainEntityOfPage: {
					'@type': 'WebPage',
					'@id': canonicalURL.toString(),
				},
				author: { '@type': 'Organization', name: SITE_TITLE },
				publisher: { '@type': 'Organization', name: SITE_TITLE },
				...(heroImage ? { image: new URL(heroImage.src, Astro.site).toString() } : {}),
			})}
		/>
		<script
			type="application/ld+json"
			set:html={JSON.stringify({
				'@context': 'https://schema.org',
				'@type': 'BreadcrumbList',
				itemListElement: [
					{ '@type': 'ListItem', position: 1, name: 'Home', item: Astro.site?.toString() },
					{ '@type': 'ListItem', position: 2, name: 'Reviews', item: new URL('/blog', Astro.site).toString() },
					{ '@type': 'ListItem', position: 3, name: title },
				],
			})}
		/>
	</head>

	<body>
		<Header />
		<main>
			<article class="max-w-3xl mx-auto">
				<!-- Breadcrumb -->
				<nav class="text-sm text-gray-400 mb-4">
					<a href="/" class="hover:text-amber-600">Home</a>
					<span class="mx-1">/</span>
					<a href="/blog" class="hover:text-amber-600">Reviews</a>
					<span class="mx-1">/</span>
					<span class="text-gray-600">{title}</span>
				</nav>

				<header class="mb-8">
					<div class="flex items-center gap-3 mb-3">
						<span class="text-sm text-amber-600 bg-amber-50 px-3 py-1 rounded">{category}</span>
						<time class="text-sm text-gray-400"><FormattedDate date={pubDate} /></time>
						{updatedDate && (
							<span class="text-sm text-gray-400">
								(Updated: <FormattedDate date={updatedDate} />)
							</span>
						)}
					</div>
					<h1 class="text-2xl md:text-3xl font-bold leading-tight">{title}</h1>
					{mangaAuthor && (
						<p class="text-gray-500 mt-1">
							by {mangaAuthor}
							{mangaTitleJa && <span class="text-gray-400 ml-2">({mangaTitleJa})</span>}
						</p>
					)}
					{rating && (
						<div class="mt-2 text-lg font-bold text-amber-600">
							Rating: {rating}/10
						</div>
					)}
					{tags && tags.length > 0 && (
						<div class="flex flex-wrap gap-2 mt-3">
							{tags.map((tag: string) => (
								<span class="text-xs text-gray-500 bg-gray-100 px-2 py-1 rounded">#{tag}</span>
							))}
						</div>
					)}
				</header>

				<AdBanner position="top" />

				<div class="prose">
					<slot />
				</div>

				{amazonASIN && amazonTitle && (
					<AffiliateLink
						href={`https://www.amazon.com/dp/${amazonASIN}?tag=${AMAZON_ASSOCIATE_TAG}`}
						text={amazonTitle}
						asin={amazonASIN}
					/>
				)}

				<AdBanner position="bottom" />

				{relatedPosts.length > 0 && (
					<div class="mt-12 pt-6 border-t border-gray-200">
						<h2 class="text-xl font-bold mb-4">Related Reviews</h2>
						<div class="grid gap-4 sm:grid-cols-3">
							{relatedPosts.map((post) => (
								<a href={`/blog/${post.id}/`} class="block p-4 rounded-lg border border-gray-200 hover:border-amber-300 hover:shadow-md transition !no-underline">
									<span class="text-xs text-amber-600 bg-amber-50 px-2 py-0.5 rounded">{post.data.category}</span>
									<h3 class="text-sm font-semibold mt-2 text-gray-800 line-clamp-2">{post.data.title}</h3>
									<p class="text-xs text-gray-500 mt-1"><FormattedDate date={post.data.pubDate} /></p>
								</a>
							))}
						</div>
					</div>
				)}

				<div class="mt-8 pt-6 border-t border-gray-200 text-center">
					<a
						href="/blog"
						class="inline-block px-6 py-3 bg-amber-600 !text-white rounded-lg !no-underline hover:bg-amber-700 hover:!text-white transition"
					>
						Browse More Reviews
					</a>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
